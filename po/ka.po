#: ../src/ddccontrol/main.c:84
#, c-format
msgid ""
"Usage:\n"
"%s [-b datadir] [-v] [-c] [-d] [-f] [-s] [-r ctrl [-w value]] [-l (profile "
"path)] [-p | dev]\n"
"\tdev: device, e.g. dev:/dev/i2c-0\n"
"\t-p : probe I2C devices to find monitor buses\n"
"\t-c : query capability\n"
"\t-d : query ctrls 0 - 255\n"
"\t-r : query ctrl\n"
"\t-w : value to write to ctrl\n"
"\t-W : relatively change ctrl value (+/-)\n"
"\t-f : force (avoid validity checks)\n"
"\t-s : save settings\n"
"\t-v : verbosity (specify more to increase)\n"
"\t-b : ddccontrol-db directory (if other than %s)\n"
"\t-l : load values from XML profile file\n"
msgstr ""
"გამოყენება:\n"
"%s [-b datadir] [-v] [-c] [-d] [-f] [-s] [-r ctrl [-w value]] [-l (პროფილის "
"ბილიკი)] [-p | dev]\n"
"\tdev: device, e.g. dev:/dev/i2c-0\n"
"\t-p : I2C მოწყობილობების ზონდირება ეკრანის სალტეების აღმოსაჩენად\n"
"\t-c : შესაძლებლობის გამოთხოვა\n"
"\t-d : კნტრლ ელემენტების გამოთხოვა 0 - 255\n"
"\t-r : კნტრლ ელემენტების გამოთხოვა\n"
"\t-w : კონტროლის ელემენტში ჩასაწერი მნიშვნელობა\n"
"\t-W : კონტროლის ელემენტის მნიშვნელობის ფარდობითი ცვლილება (+/-)\n"
"\t-f : ნაძალადევი (სისწორის შემოწმებების გამოტოვება)\n"
"\t-s : პარამეტრების შენახვა\n"
"\t-v : გამოტანილი შეტყობინებების დაწვრილმანება (გასაზრდელად მიუთითეთ ერთზე "
"მეტჯერ)\n"
"\t-b : ddccontrol-db საქაღალდე (თუ განსხვავდება მნიშვნელობისგან %s)\n"
"\t-l : მნიშვნელობების წაკითხვა XML პროფილის ფაილიდან\n"

